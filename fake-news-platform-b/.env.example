# 🔧 Environment Configuration — OSINT Platform
# Copy this file to .env and fill in your values

# ========================================
# DATABASE CONFIGURATION
# ========================================

DB_HOST=localhost
DB_PORT=3306
DB_USER=osint_user
DB_PASSWORD=SecurePassword123!
DB_NAME=fake_news_platform
DB_CHARSET=utf8mb4

# ========================================
# APPLICATION SETTINGS
# ========================================

APP_NAME=OSINT Intelligence Platform
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/fake-news-platform-b

# ========================================
# CHROME BROWSER CONFIGURATION
# ========================================

# Path to Google Chrome executable
# Windows: C:/Program Files/Google/Chrome/Application/chrome.exe
# Linux: /usr/bin/google-chrome
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROME_EXECUTABLE=C:/Program Files/Google/Chrome/Application/chrome.exe

# Directory for Chrome persistent session
# WARNING: Do NOT use main Chrome User Data directory
# Use a separate folder to avoid lock conflicts
CHROME_USER_DATA=chrome_session

# Launch Chrome in headless mode (faster, no visual)
CHROME_HEADLESS=true

# Chrome launch timeout (seconds)
CHROME_TIMEOUT=30

# Disable images during extraction (faster)
CHROME_DISABLE_IMAGES=true

# ========================================
# PYTHON CONFIGURATION
# ========================================

# Chemin vers le Python du venv (Linux — adapter selon votre machine)
PYTHON_EXECUTABLE=/home/kali/gbert_project/venv/bin/python3

# AI Model for NLP analysis
# Options:
#  - gbert-hassaniya (votre modèle AraBERT+AraGPT2 fine-tuné Hassaniya)
#  - cardiffnlp/twitter-xlm-roberta-base-sentiment (default, multilingual)
#  - aubmindlab/bert-base-arabertv02 (Arabic)
AI_MODEL=gbert-hassaniya

# Poids du modèle GBERT (optionnel si déjà dans python-ai/models/)
GBERT_MODEL_PATH=/home/kali/gbert_project/gbert_hassaniya_FINAL.pt

# Serveur IA persistant (FastAPI — lancer avec python-ai/start_ai_server.sh)
AI_SERVER_URL=http://127.0.0.1:8765
AI_SERVER_HOST=127.0.0.1
AI_SERVER_PORT=8765

# Analyse automatique après chaque scrape Facebook
AI_AUTO_ANALYZE=true

# ========================================
# LOGGING CONFIGURATION
# ========================================

LOG_DIR=/var/log/osint
LOG_LEVEL=info

# API/Extraction logging
LOG_FILE_EXTRACTION=api/extractor_log.txt

# Python script logging
LOG_FILE_PYTHON=python-ai/execution.log

# PHP error logging
LOG_FILE_PHP=/var/log/osint/php_error.log

# ========================================
# SECURITY SETTINGS
# ========================================

# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Requests allowed per time window
RATE_LIMIT_REQUESTS=10

# Time window in seconds
RATE_LIMIT_WINDOW=60

# HTTPS only (set to true in production)
FORCE_HTTPS=false

# Session timeout (minutes)
SESSION_TIMEOUT=480

# ========================================
# API SETTINGS
# ========================================

# Maximum file upload size (MB)
MAX_UPLOAD_SIZE=50

# Maximum POST body size (MB)
MAX_POST_SIZE=10

# Response timeout (seconds)
API_TIMEOUT=300

# Enable CORS (for cross-origin requests)
CORS_ENABLED=false
CORS_ORIGIN=http://localhost:3000

# ========================================
# EXTRACTION SETTINGS
# ========================================

# Maximum concurrent Chrome instances
MAX_CONCURRENT_EXTRACTIONS=2

# Extraction timeout (seconds)
EXTRACTION_TIMEOUT=30

# Wait for page load (milliseconds)
PAGE_LOAD_WAIT=5000

# ========================================
# EMAIL NOTIFICATIONS (OPTIONAL)
# ========================================

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_username
MAIL_PASSWORD=your_password
MAIL_FROM=noreply@osint.company.com

# ========================================
# EXTERNAL SERVICES (OPTIONAL)
# ========================================

# Slack integration for alerts
SLACK_WEBHOOK_URL=

# DataDog monitoring
DATADOG_API_KEY=

# Sentry error tracking
SENTRY_DSN=

# ========================================
# DEVELOPMENT SETTINGS
# ========================================

# Verbose logging (very detailed)
VERBOSE=false

# Keep Chrome windows open (for debugging)
DEBUG_BROWSER=false

# Enable query logging
DEBUG_SQL=false

# API response time statistics
DEBUG_TIMING=false

# ========================================
# PRODUCTION OVERRIDES
# ========================================

# Copy and modify for production .env:

# APP_ENV=production
# APP_DEBUG=false
# FORCE_HTTPS=true
# CHROME_HEADLESS=true
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=5
# SESSION_TIMEOUT=240
# VERBOSE=false
# DEBUG_BROWSER=false
# DEBUG_SQL=false
# DEBUG_TIMING=false
